# ------------------------------------------------------------------------------
# Provider / API credentials
# ------------------------------------------------------------------------------
# API key for Alias Robotics provider or a fallback API key for certain tools.
ALIAS_API_KEY=""
# API key for Anthropic models (Claude family).
ANTHROPIC_API_KEY=""
# API key for Google Custom Search API.
GOOGLE_SEARCH_API_KEY=""
# Google Custom Search Engine ID (cx) used with `GOOGLE_SEARCH_API_KEY`.
GOOGLE_SEARCH_CX=""
# API key used by LiteLLM when contacting a remote liteLLM proxy.
LITELLM_API_KEY=""
# Base URL for a LiteLLM proxy (e.g. http://localhost:4000).
LITELLM_BASE_URL=""
# Toggle/flag to indicate use of Ollama locally (boolean) or custom indicator.
OLLAMA=""

# ------------------------------------------------------------------------------
# Universal Local API (Ollama / vLLM / llama.cpp / any OpenAI-compatible server)
# ------------------------------------------------------------------------------
# Point all agents at a local OpenAI-compatible inference server (base URL).
LOCAL_API_BASE=""
# API key for your local inference server (propagated to OPENAI_API_KEY by bootstrap).
LOCAL_API_KEY=""
# Base URL specifically for Ollama deployments (if used instead of LOCAL_API_BASE).
OLLAMA_API_BASE=""
# API key for Ollama (when required by your Ollama deployment).
OLLAMA_API_KEY=""
# Primary OpenAI API key (or compatible provider key). Used as the default model key.
OPENAI_API_KEY="sk-..."
# Base URL for an OpenAI-compatible endpoint (overrides provider default when set).
OPENAI_BASE_URL=""
# Optional OpenAI organization id for multi-tenant accounts.
OPENAI_ORG_ID=""
# Optional OpenAI/Azure project id used by some providers.
OPENAI_PROJECT_ID=""
# API key for Perplexity (if using Perplexity integrations).
PERPLEXITY_API_KEY=""
# API key for Shodan (used by certain scanning tools).
SHODAN_API_KEY=""

# ------------------------------------------------------------------------------
# Core CAI runtime settings
# ------------------------------------------------------------------------------
# Default agent runtime type (one_tool_agent, redteam_agent, etc.).
CEREBRO_AGENT_TYPE="one_tool_agent"
# If true (or set), the agent will produce briefer outputs where supported.
CEREBRO_BRIEF="false"
# Timeout (seconds) for code execution tools run by agents.
CEREBRO_CODE_TIMEOUT=""
# Debug verbosity (0=off, 1=normal, 2=verbose developer debug).
CEREBRO_DEBUG="1"
# Enable additional streaming debug logging for token-level flows.
CEREBRO_DEBUG_STREAMING="false"
# Global guardrails toggle; set to "false" to disable guardrail checks.
CEREBRO_GUARDRAILS="true"
# Maximum turns allowed in a session before stopping (numeric or empty for unlimited).
CEREBRO_MAX_TURNS=""
# Default model identifier used by agents when none is specified.
CEREBRO_MODEL="alias1"
# Number of parallel agents to run concurrently (numeric).
CEREBRO_PARALLEL="1"
# Comma-separated list of parallel agent names for multi-agent runs.
CEREBRO_PARALLEL_AGENTS=""
# Freeform description used when creating or selecting agent pattern templates.
CEREBRO_PATTERN_DESCRIPTION=""
# Soft price/usage limit to constrain API spend (currency units per run/session).
CEREBRO_PRICE_LIMIT="0"
# Reporting mode for runs (e.g., 'ctf', 'report', 'json').
CEREBRO_REPORT="ctf"
# Whether CAI should persist state between runs (session state storage).
CEREBRO_STATE="false"

# Optional behavior toggles and mode settings
# Enable streaming outputs (token-by-token) when supported by model/provider.
CEREBRO_STREAM="true"
# How often (turns) the support agent should intervene or summarize (numeric).
CEREBRO_SUPPORT_INTERVAL=""
# Model override used for internal support/summarizer tasks.
CEREBRO_SUPPORT_MODEL=""
# Enable telemetry (usage/anonymous metrics) backends.
CEREBRO_TELEMETRY="true"
# Enable tracing for distributed traces / opentelemetry.
CEREBRO_TRACING="true"

# ------------------------------------------------------------------------------
# Workspace / container / shell integration
# ------------------------------------------------------------------------------
# Name or ID of the active container to run tools inside (optional).
CEREBRO_ACTIVE_CONTAINER=""
# Name of the workspace or project being used by this CAI instance.
CEREBRO_WORKSPACE=""
# Path to the workspace directory (useful in containerised setups).
CEREBRO_WORKSPACE_DIR=""

# SSH default connection parameters used by certain remote tools.
SSH_HOST=""
SSH_PASS=""
SSH_USER=""

# ------------------------------------------------------------------------------
# Memory / context controls
# ------------------------------------------------------------------------------
# Controls whether agent handoffs between agents are handled automatically.
CEREBRO_AGENT_SWITCH_HANDLED="false"
# Estimated fraction of context allowed to be used (0.0-1.0) for memory budgeting.
CEREBRO_CONTEXT_USAGE="0.0"
# Whether to show cost in runs when known (true/false).
CEREBRO_COST_DISPLAYED="false"
# If set, forces the run to start as a particular named agent.
CEREBRO_CURRENT_AGENT=""
# Memory mode (false/episodic/semantic/all). Controls whether RAG/memory is used.
CEREBRO_MEMORY="false"

# Internal memory collection names (managed by CAI runtime).
CEREBRO_MEMORY_COLLECTION=""
# Toggle for offline/local memory ingestion (true/false).
CEREBRO_MEMORY_OFFLINE="false"
# Toggle for online/remote memory usage (true/false).
CEREBRO_MEMORY_ONLINE="false"
# Interval (minutes) between online memory updates when enabled.
CEREBRO_MEMORY_ONLINE_INTERVAL="5"

# Whether screenshots captured by the browser tool should be embedded into memory.
CEREBRO_EMBED_SCREENSHOT="true"
# Maximum age (hours) of screenshots to retain before cleanup.
CEREBRO_SCREENSHOT_MAX_AGE_HOURS="24"
# Number of screenshots to keep per target (older ones pruned).
CEREBRO_SCREENSHOT_KEEP_N="5"

# ------------------------------------------------------------------------------
# Session / environment behavior flags
# ------------------------------------------------------------------------------
# Auto-compact conversation history into smaller memory summaries (true/false).
CEREBRO_AUTO_COMPACT="false"
# Confidence threshold (fraction) used when auto-compacting context (0.0-1.0).
CEREBRO_AUTO_COMPACT_THRESHOLD=""
# Disable recording full session transcripts to disk when true.
CEREBRO_DISABLE_SESSION_RECORDING="false"
# Disable anonymous usage tracking when set to true.
CEREBRO_DISABLE_USAGE_TRACKING="false"
# Include environment/context information in system prompts when true.
CEREBRO_ENV_CONTEXT="true"

# Disable agent tracing via OpenAIAgents bridge (leave empty or 'true' to disable).
OPENAI_AGENTS_DISABLE_TRACING=""
# When set to 1, prompt_toolkit will not attempt CPR-aware input handling.
PROMPT_TOOLKIT_NO_CPR=1
# Generic Python warnings override (e.g., "ignore::DeprecationWarning").
PYTHONWARNINGS=""

# ------------------------------------------------------------------------------
# CTF / target configuration (used by ctfs/examples)
# ------------------------------------------------------------------------------
# Name or identifier of the CTF challenge you are targeting.
CTF_CHALLENGE=""
# Whether the CTF target is inside a network (true/false).
CTF_INSIDE="true"
# IP address of the target CTF host.
CTF_IP="192.168.3.100"
# Optional model override used for special CTF runs.
CTF_MODEL=""
# Human-readable name for the CTF run or target.
CTF_NAME=""
# Subnet used for scanning / network assumptions.
CTF_SUBNET="192.168.3.0/24"

# ------------------------------------------------------------------------------
# Vision / VLM configuration
# ------------------------------------------------------------------------------
# Identifier of the vision-capable model to use for screenshot description (e.g., 'ollama/llava' or 'openai/gpt-4o-mini-vision').
CEREBRO_VISION_MODEL=""

# ------------------------------------------------------------------------------
# Rate-limiting / networking / security related vars
# ------------------------------------------------------------------------------
# Comma-separated list of trusted proxies (used when parsing remote IPs).
TRUSTED_PROXIES=""
# Maximum number of unique IPs to retain for simple rate-limiting.
RATE_LIMIT_MAX_IPS="10000"
# Number of seconds to keep IP rate-limit entries (default: 7 days).
RATE_LIMIT_IP_TTL_SECONDS="604800"

# ------------------------------------------------------------------------------
# CI / Test / Example variables
# ------------------------------------------------------------------------------
# When true, long-running integration tests that invoke agents will run.
RUN_AGENT_INTEGRATION_TESTS="false"
# GitHub token used by some tooling that integrates with GitHub APIs.
GITHUB_TOKEN=""

# Example provider variables used in example configs and custom adapters.
# Base URL for a custom example provider.
EXAMPLE_BASE_URL=""
# API key for a custom example provider.
EXAMPLE_API_KEY=""
# Model name to use with a custom example provider.
EXAMPLE_MODEL_NAME=""
# Generic LLM model override used in examples and testing.
LLM_MODEL="qwen2.5:14b"

# ------------------------------------------------------------------------------
# Vault / secret manager integration (optional)
# ------------------------------------------------------------------------------
# HashiCorp Vault address used by some secret managers.
HCP_VAULT_ADDR="http://127.0.0.1:8200"
# HashiCorp Vault token used for secret retrieval.
HCP_VAULT_TOKEN=""
# Optional Vault namespace when using Vault Enterprise features.
HCP_VAULT_NAMESPACE=""
# Optional client certificate path for Vault TLS client auth.
HCP_VAULT_CLIENT_CERT=""
# Optional client key path for Vault TLS client auth.
HCP_VAULT_CLIENT_KEY=""
# Azure Key Vault URI (used by some third-party components).
AZURE_KEY_VAULT_URI=""

# ------------------------------------------------------------------------------
# Model provider convenience variables
# ------------------------------------------------------------------------------
# Alternative host / base URL for LiteLLM if using a remote proxy.
LITELLM_BASE_URL="http://localhost:4000"
# API key used by LiteLLM proxy setups.
LITELLM_API_KEY=""

# ------------------------------------------------------------------------------
# Agent-specific model overrides
# ------------------------------------------------------------------------------
# Per-agent model overrides allow tuning each agent independently.
CEREBRO_ANDROID_SAST_MODEL=""
CEREBRO_APP_LOGIC_MAPPER_MODEL=""
CEREBRO_BB_TRIAGE_SWARM_PATTERN_MODEL=""
CEREBRO_BLUE_TEAM_RED_TEAM_SHARED_CONTEXT_MODEL=""
CEREBRO_BLUE_TEAM_RED_TEAM_SPLIT_CONTEXT_MODEL=""
CEREBRO_BLUETEAM_AGENT_MODEL=""
CEREBRO_BUG_BOUNTER_1_MODEL=""
CEREBRO_BUG_BOUNTER_AGENT_MODEL=""
CEREBRO_DFIR_AGENT_MODEL=""
CEREBRO_DNS_SMTP_AGENT_MODEL=""
CEREBRO_FLAG_DISCRIMINATOR_MODEL=""
CEREBRO_INJECTION_DETECTOR_AGENT_MODEL=""
CEREBRO_MEMORY_ANALYSIS_AGENT_MODEL=""
CEREBRO_NETWORK_SECURITY_ANALYZER_AGENT_MODEL=""
CEREBRO_OFFSEC_PATTERN_MODEL=""
CEREBRO_ONE_TOOL_AGENT_MODEL=""
CEREBRO_REDTEAM_AGENT_MODEL=""
CEREBRO_REDTEAM_SWARM_PATTERN_MODEL=""
CEREBRO_REPLAY_ATTACK_AGENT_MODEL=""
CEREBRO_REPORTING_AGENT_MODEL=""
CEREBRO_RETESTER_AGENT_MODEL=""
CEREBRO_REVERSE_ENGINEERING_AGENT_MODEL=""
CEREBRO_SUBGHZ_SDR_AGENT_MODEL=""
CEREBRO_THOUGHT_AGENT_MODEL=""
CEREBRO_USE_CASE_AGENT_MODEL=""
CEREBRO_WEB_PENTESTER_AGENT_MODEL=""
CEREBRO_WIFI_SECURITY_AGENT_MODEL=""

# ------------------------------------------------------------------------------
# End of example environment variables
# ------------------------------------------------------------------------------
# ------------------------------------------------------------------------------
# Provider / API credentials
# ------------------------------------------------------------------------------
ALIAS_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""
LITELLM_API_KEY=""
LITELLM_BASE_URL=""
OLLAMA=""

# ------------------------------------------------------------------------------
# Universal Local API (Ollama / vLLM / llama.cpp / any OpenAI-compatible server)
# ------------------------------------------------------------------------------
# Set LOCAL_API_BASE to point ALL agents at a local inference server with a
# single variable.  Priority chain (highest → lowest):
#   LOCAL_API_BASE  →  OPENAI_API_BASE  →  OPENAI_BASE_URL  →  provider default
#
# Examples:
#   LOCAL_API_BASE="http://localhost:11434/v1"   # Ollama
#   LOCAL_API_BASE="http://localhost:8000/v1"    # vLLM / llama.cpp
#   LOCAL_API_BASE="http://localhost:1234/v1"    # LM Studio
LOCAL_API_BASE=""

# OpenAI-compatible and LiteLLM endpoints
OLLAMA_API_BASE=""
OLLAMA_API_KEY=""
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL=""
OPENAI_ORG_ID=""

# Ollama
OPENAI_PROJECT_ID=""
PERPLEXITY_API_KEY=""
SHODAN_API_KEY=""

# ------------------------------------------------------------------------------
# Core CAI runtime
# ------------------------------------------------------------------------------
CEREBRO_AGENT_TYPE="one_tool_agent"
CEREBRO_BRIEF="false"
CEREBRO_CODE_TIMEOUT=""
CEREBRO_DEBUG="1"
CEREBRO_DEBUG_STREAMING="false"
