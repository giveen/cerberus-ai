CEREBRO_MODEL="alias1"
CEREBRO_PARALLEL="1"
CEREBRO_PARALLEL_AGENTS=""
CEREBRO_PATTERN_DESCRIPTION=""
CEREBRO_PRICE_LIMIT="0"
CEREBRO_REPORT="ctf"
CEREBRO_STATE="false"

# Optional behavior / modes
CEREBRO_STREAM="true"
CEREBRO_SUPPORT_INTERVAL=""
CEREBRO_SUPPORT_MODEL=""
CEREBRO_TELEMETRY="true"
CEREBRO_TRACING="true"

